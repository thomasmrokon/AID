# OpenAI API Key – wird nur für Briefing-Parsing und Report-Formulierung genutzt
OPENAI_API_KEY=sk-...

# Optional: Modell-Auswahl (Default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Signierschlüssel für Login-Session-Cookies (Pflicht, zufällig, nie committen).
# deploy.sh generiert diesen automatisch, falls er hier leer/fehlend ist.
# Manuell erzeugen mit: python3 -c "import secrets; print(secrets.token_hex(32))"
AID_COOKIE_KEY=
