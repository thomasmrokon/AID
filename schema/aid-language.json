{
  "meta": {
    "version": "0.1.0",
    "project": "Augmented Industrial Designer",
    "description": "Formale Raumsprache für regelbasierte Industriegebäudeplanung"
  },
  "vocabulary": {
    "spaceTypes": {
      "PRODUKTIONSZELLE": {
        "minArea": 200,
        "minClearHeight": 6.0,
        "floorLoad": 10,
        "media": ["strom", "druckluft", "abwasser"],
        "temperatureClass": "controlled",
        "noiseClass": "high"
      },
      "PUFFER": {
        "minArea": 50,
        "minClearHeight": 4.5,
        "floorLoad": 10,
        "media": [],
        "temperatureClass": "unconditioned",
        "noiseClass": "low"
      },
      "ANDOCKZONE": {
        "minArea": 80,
        "minClearHeight": 5.0,
        "floorLoad": 15,
        "media": ["strom"],
        "dockCount": 2,
        "externalAccess": true
      },
      "TECHNIKRAUM": {
        "minArea": 30,
        "minClearHeight": 3.0,
        "floorLoad": 5,
        "media": ["strom", "wasser"],
        "externalWallRequired": true
      },
      "LAGER": {
        "minArea": 100,
        "minClearHeight": 8.0,
        "floorLoad": 20,
        "media": ["strom"],
        "rackingPossible": true
      }
    }
  },
  "grammar": {
    "relationTypes": [
      "MUSS_GRENZEN_AN",
      "BENOETIGT_NAHE",
      "DARF_NICHT_GRENZEN_AN",
      "MATERIALFLUSS_ZU",
      "UEBERWACHT",
      "VERSORGT"
    ],
    "relations": [
      {
        "id": "R01",
        "subject": "PRODUKTIONSZELLE",
        "relation": "BENOETIGT_NAHE",
        "object": "PUFFER",
        "minCount": 1,
        "maxDistance": 15,
        "priority": "MUST"
      },
      {
        "id": "R02",
        "subject": "ANDOCKZONE",
        "relation": "MUSS_GRENZEN_AN",
        "object": "LAGER",
        "priority": "MUST"
      },
      {
        "id": "R03",
        "subject": "TECHNIKRAUM",
        "relation": "DARF_NICHT_GRENZEN_AN",
        "object": "PRODUKTIONSZELLE",
        "priority": "SHOULD"
      },
      {
        "id": "R04",
        "subject": "PRODUKTIONSZELLE",
        "relation": "MATERIALFLUSS_ZU",
        "object": "PRODUKTIONSZELLE",
        "maxDepth": 3,
        "priority": "SHOULD"
      }
    ]
  },
  "syntax": {
    "patterns": {
      "FISCHGRAETE": {
        "description": "Hauptgasse mit Produktionszellen seitlich",
        "spine": "ANDOCKZONE → LAGER → PUFFER",
        "branches": "PRODUKTIONSZELLE",
        "gridX": 12,
        "gridY": 24
      },
      "U_FLUSS": {
        "description": "U-förmiger Materialfluss, Eingang gleich Ausgang",
        "flow": "ANDOCKZONE → LAGER → PRODUKTION → LAGER → ANDOCKZONE",
        "gridX": 12,
        "gridY": 18
      },
      "HALLENRASTER": {
        "description": "Freie Halle mit Standardraster",
        "gridX": 12,
        "gridY": 24,
        "columnGrid": 6
      }
    }
  },
  "consensusProtocol": {
    "maxIterations": 5,
    "consensusConditions": [
      "ruleViolations.length === 0",
      "conflicts.length === 0",
      "syntaxScore >= 0.8"
    ],
    "escalationOnFail": "notify_user_telegram",
    "conflictResolution": "priority_order",
    "priorityOrder": [
      "userRequirements",
      "produktionsablauf",
      "layout",
      "tragwerk",
      "tga"
    ]
  }
}
